# Committed devcontainer environment — safe, dev-only values, NO real secrets.
# Loaded by the `app` service (docker-compose env_file). The "example that just
# works". Real secrets stay in the existing secret manager for non-container use.
#
# NOTE: lifecycle hooks re-source this file (set -a; . devcontainer.env; set +a)
# because DevPod truncates env_file values at '='. (GOTCHAS #1)

# --- Database (postgres service, fixed dev creds) ---
DATABASE_URL=postgres://{{DB_USER}}:{{DB_PASS}}@postgres:5432/{{DB_NAME}}?schema=public
DIRECT_URL=postgres://{{DB_USER}}:{{DB_PASS}}@postgres:5432/{{DB_NAME}}?schema=public
# Only `prisma migrate dev` uses the shadow DB; the push-based post-create
# lifecycle never touches it. Drop this line for a non-migrate workflow.
SHADOW_DATABASE_URL=postgres://{{DB_USER}}:{{DB_PASS}}@postgres:5432/shadow?schema=public

# --- Redis (redis service) ---
REDIS_URL=redis://redis:6379

# --- App auth/session (dev-only placeholders) ---
# The app is reached via devrouter (no host port), so these must be the routed
# https host (auth callbacks + cookie domain).
NEXTAUTH_SECRET=local-dev-not-a-secret-change-me
NEXTAUTH_URL=https://{{APP}}.localhost

# --- Public, browser-facing URLs (routed by devrouter) ---
NEXT_PUBLIC_APP_URL=https://{{APP}}.localhost

# --- Local OIDC (mock-oauth2-server sidecar, replaces Auth0) ---
# Routed by devrouter (oidc.{{APP}}.localhost -> the app's netns :{{OIDC_PORT}}).
# The SAME issuer host is used by the browser (authorize) and the app server
# (discovery/token/jwks) — the app resolves it via extra_hosts -> host gateway
# and trusts the mkcert CA via NODE_EXTRA_CA_CERTS — so the token `iss` matches.
AUTH0_ISSUER=https://oidc.{{APP}}.localhost/default
AUTH0_CLIENT_ID={{APP}}-local
AUTH0_CLIENT_SECRET=local-dev-secret

# Trust the local mkcert CA (mounted in docker-compose.yml) so server-side HTTPS
# fetches to https://oidc.{{APP}}.localhost verify cleanly. (GOTCHAS #16)
NODE_EXTRA_CA_CERTS=/etc/devrouter/mkcert-rootCA.pem
