# Committed devcontainer environment — safe, dev-only values, NO real secrets.
# Loaded by the `app` service (docker-compose env_file). The "example that just
# works". Real secrets stay in the existing secret manager for non-container use.
#
# NOTE: lifecycle hooks re-source this file (set -a; . devcontainer.env; set +a)
# because DevPod truncates env_file values at '='. (GOTCHAS #1)

# --- Database (postgres service, fixed dev creds) ---
DATABASE_URL=postgres://{{DB_USER}}:{{DB_PASS}}@postgres:5432/{{DB_NAME}}?schema=public
DIRECT_URL=postgres://{{DB_USER}}:{{DB_PASS}}@postgres:5432/{{DB_NAME}}?schema=public
SHADOW_DATABASE_URL=postgres://{{DB_USER}}:{{DB_PASS}}@postgres:5432/shadow?schema=public

# --- Redis (redis service) ---
REDIS_URL=redis://redis:6379

# --- App auth/session (dev-only placeholders) ---
NEXTAUTH_SECRET=local-dev-not-a-secret-change-me
NEXTAUTH_URL=http://localhost:{{APP_PORT}}

# --- Public, browser-facing URLs ---
NEXT_PUBLIC_APP_URL=http://localhost:{{APP_PORT}}

# --- Local OIDC (mock-oauth2-server sidecar, replaces Auth0) ---
# Same URL resolves from the app server and host browser because the OIDC mock
# shares the app container's network namespace (see docker-compose.yml).
AUTH0_ISSUER=http://localhost:{{OIDC_PORT}}/default
AUTH0_CLIENT_ID={{APP}}-local
AUTH0_CLIENT_SECRET=local-dev-secret
